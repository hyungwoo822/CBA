# ============================================================
# brain-agent Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API key(s).
#   cp .env.example .env
#
# LiteLLM auto-detects the correct key based on your model prefix.
# You only need ONE provider key to get started.
# ============================================================

# --- LLM Provider API Keys (set at least one) ---

# OpenAI  (models: openai/gpt-4o, openai/gpt-4o-mini, ...)
OPENAI_API_KEY=""

# Anthropic Claude  (models: anthropic/claude-sonnet-4-20250514, ...)
ANTHROPIC_API_KEY=""

# Google Gemini  (models: gemini/gemini-2.0-flash, gemini/gemini-pro, ...)
GEMINI_API_KEY=""

# xAI Grok  (models: xai/grok-2, xai/grok-3, ...)
XAI_API_KEY=""

# --- Channel Tokens (for brain-agent serve) ---

# Telegram Bot  (get from @BotFather)
# TELEGRAM_BOT_TOKEN=""

# Discord Bot  (get from Discord Developer Portal)
# DISCORD_BOT_TOKEN=""

# --- Tracing (LangFuse — default) ---

# LANGFUSE_PUBLIC_KEY="pk-..."
# LANGFUSE_SECRET_KEY="sk-..."
# LANGFUSE_HOST="https://cloud.langfuse.com"

# --- Tracing (LangSmith — alternative) ---

# LANGCHAIN_TRACING_V2="true"
# LANGSMITH_API_KEY=""
# LANGSMITH_PROJECT="brain-agent"

# --- Optional Settings ---

# Override default model (default: openai/gpt-4o-mini)
# BRAIN_AGENT_MODEL="anthropic/claude-sonnet-4-20250514"
